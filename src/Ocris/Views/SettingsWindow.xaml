<Window x:Class="Ocris.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置 · Ocris" Height="560" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="540"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLightBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                    <TextBlock Text="⚙" Foreground="White" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="设置" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="· Ocris" FontSize="13" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>

                <!-- AI 配置 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="AI 配置" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="API Token" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Name="txtApiToken" Style="{StaticResource FieldTextBox}"
                                     Text="{Binding ApiToken, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="API 地址" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Name="txtApiBaseUrl" Style="{StaticResource FieldTextBox}"
                                     Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="阿里云 API Key" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Name="txtAliCloudApiKey" Style="{StaticResource FieldTextBox}"
                                     Text="{Binding AliCloudApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="阿里云 API 地址" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Name="txtAliCloudApiBaseUrl" Style="{StaticResource FieldTextBox}"
                                     Text="{Binding AliCloudApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Button Content="测试连接" Style="{StaticResource InfoButton}" Command="{Binding TestConnectionCommand}"
                                HorizontalAlignment="Right" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 快捷键 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="快捷键" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="截图快捷键" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Name="txtScreenshotHotkey" Style="{StaticResource FieldTextBox}" IsReadOnly="True"
                                     Text="{Binding ScreenshotHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="主窗口快捷键" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Name="txtMainWindowHotkey" Style="{StaticResource FieldTextBox}" IsReadOnly="True"
                                     Text="{Binding MainWindowHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBlock Text="提示：修改快捷键请编辑 config.json 的 Hotkeys 段，重启生效。" FontSize="11" Foreground="{DynamicResource TextFaintBrush}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 截图 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="截图" Style="{StaticResource SectionTitle}"/>
                        <CheckBox Name="chkAutoSaveScreenshots" Content="自动保存截图到本地" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                  IsChecked="{Binding AutoSaveScreenshots}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="保存路径" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="1" Name="txtScreenshotPath" Style="{StaticResource FieldTextBox}"
                                     Text="{Binding ScreenshotPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="浏览" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                    Command="{Binding BrowsePathCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 界面 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="界面" Style="{StaticResource SectionTitle}"/>
                        <CheckBox Name="chkWindowTopmost" Content="启动时窗口置顶" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                  IsChecked="{Binding WindowTopmost}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="主题" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" Name="cmbTheme" Width="160" Padding="8,5" FontSize="13"
                                      SelectedValue="{Binding SelectedTheme}">
                                <ComboBoxItem Content="浅色主题" Tag="Light"/>
                                <ComboBoxItem Content="深色主题" Tag="Dark"/>
                                <ComboBoxItem Content="跟随系统" Tag="Auto"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="恢复默认" Style="{StaticResource SecondaryButton}" Command="{Binding ResetDefaultCommand}" Margin="0,0,8,0"/>
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                <Button Content="保存" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
