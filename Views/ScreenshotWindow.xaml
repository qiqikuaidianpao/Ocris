<Window x:Class="AIAnswerTool.Views.ScreenshotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="截图选择"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">
    
    <Grid Name="MainGrid">
        <!-- 背景遮罩 -->
        <Rectangle Name="BackgroundMask"
                   Fill="Black"
                   Opacity="0.3" />
        
        <!-- 选择区域 -->
        <Canvas Name="SelectionCanvas">
            <!-- 选择矩形 -->
            <Rectangle Name="SelectionRectangle"
                       Stroke="Red"
                       StrokeThickness="2"
                       Fill="Transparent"
                       Visibility="Collapsed" />
            
            <!-- 选择区域信息 -->
            <Border Name="InfoPanel"
                    Background="#CC000000"
                    Padding="8,4"
                    Visibility="Collapsed">
                <TextBlock Name="InfoText"
                           Foreground="White"
                           FontSize="12"
                           FontFamily="Consolas" />
            </Border>
            <!-- 工具栏 -->
            <Border Name="ToolBar"
                    Background="#F2F2F2"
                    CornerRadius="5"
                    Padding="5"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Button Name="ConfirmButton"
                            Style="{StaticResource ToolBarButton}"
                            Click="ConfirmButton_Click">
                        <Path Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41,-1.41L9,16.17z" 
                              Fill="#4CAF50" 
                              Width="20" 
                              Height="20" 
                              Stretch="Uniform" />
                    </Button>
                    <Button Name="CancelButton"
                            Style="{StaticResource ToolBarButton}"
                            Click="CancelButton_Click">
                        <Path Data="M19,6.41L17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12 19,6.41z" 
                              Fill="#F44336" 
                              Width="20" 
                              Height="20" 
                              Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>
        
        <!-- 帮助信息 -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Background="#CC000000"
                Padding="15,8">
            <StackPanel>
                <TextBlock Text="截图选择"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5" />
                <TextBlock Text="拖拽鼠标选择截图区域"
                           Foreground="#CCFFFFFF"
                           FontSize="12"
                           HorizontalAlignment="Center" />
                <TextBlock Text="按 ESC 键取消截图"
                           Foreground="#CCFFFFFF"
                           FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
        

    </Grid>
</Window>