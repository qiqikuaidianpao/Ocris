<Window x:Class="AIAnswerTool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="500">
    
    <Window.Resources>
        <!-- 现代化样式定义 -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="GroupBoxHeaderStyle" TargetType="GroupBox">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="⚙️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="应用设置" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333"/>
            </Grid>
        </Border>
        
        <!-- 主要设置内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                
                <!-- AI 配置 -->
                <GroupBox Header="AI 配置" Style="{StaticResource GroupBoxHeaderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="API Token:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Name="txtApiToken" 
                                 Style="{StaticResource ModernTextBoxStyle}" 
                                 Margin="10,5,0,5"
                                 Text="{Binding ApiToken, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="API 地址:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Name="txtApiBaseUrl" 
                                 Style="{StaticResource ModernTextBoxStyle}" 
                                 Margin="10,5,0,5"
                                 Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="阿里云API Key:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Name="txtAliCloudApiKey" 
                                 Style="{StaticResource ModernTextBoxStyle}" 
                                 Margin="10,5,0,5"
                                 Text="{Binding AliCloudApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="阿里云API地址:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Name="txtAliCloudApiBaseUrl" 
                                 Style="{StaticResource ModernTextBoxStyle}" 
                                 Margin="10,5,0,5"
                                 Text="{Binding AliCloudApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,10,0,0">
                            <Button Content="测试连接" Style="{StaticResource ModernButtonStyle}" 
                                    Command="{Binding TestConnectionCommand}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
                
                <!-- 快捷键设置 -->
                <GroupBox Header="快捷键设置" Style="{StaticResource GroupBoxHeaderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="截图快捷键:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Name="txtScreenshotHotkey" 
                                 Style="{StaticResource ModernTextBoxStyle}" 
                                 Margin="10,5,0,5" IsReadOnly="True"
                                 Text="{Binding ScreenshotHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="主窗口快捷键:" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Name="txtMainWindowHotkey" 
                                 Style="{StaticResource ModernTextBoxStyle}" 
                                 Margin="10,5,0,5" IsReadOnly="True"
                                 Text="{Binding MainWindowHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="提示：点击输入框后按下新的快捷键组合来修改" 
                                   FontSize="11" Foreground="#666" Margin="10,5,0,5"/>
                    </Grid>
                </GroupBox>
                
                <!-- 截图设置 -->
                <GroupBox Header="截图设置" Style="{StaticResource GroupBoxHeaderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="保存截图:" VerticalAlignment="Center" Margin="0,5"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" Name="chkAutoSaveScreenshots" 
                                  Content="自动保存截图到本地" 
                                  IsChecked="{Binding AutoSaveScreenshots}" 
                                  VerticalAlignment="Center" Margin="10,5,0,5"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="保存路径:" VerticalAlignment="Center" Margin="0,5"/>
                        <Grid Grid.Row="1" Grid.Column="1" Margin="10,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox Grid.Column="0" Name="txtScreenshotPath" 
                                     Style="{StaticResource ModernTextBoxStyle}" 
                                     Text="{Binding ScreenshotPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="浏览" Style="{StaticResource ModernButtonStyle}" 
                                    Margin="5,0,0,0" Command="{Binding BrowsePathCommand}"/>
                        </Grid>
                    </Grid>
                </GroupBox>
                
                <!-- 界面设置 -->
                <GroupBox Header="界面设置" Style="{StaticResource GroupBoxHeaderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="窗口置顶:" VerticalAlignment="Center" Margin="0,5"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" Name="chkWindowTopmost" 
                                  Content="启动时窗口置顶" 
                                  IsChecked="{Binding WindowTopmost}" 
                                  VerticalAlignment="Center" Margin="10,5,0,5"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="主题:" VerticalAlignment="Center" Margin="0,5"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" Name="cmbTheme" 
                                  Margin="10,5,0,5" Width="150" HorizontalAlignment="Left"
                                  SelectedValue="{Binding SelectedTheme}">
                            <ComboBoxItem Content="浅色主题" Tag="Light"/>
                            <ComboBoxItem Content="深色主题" Tag="Dark"/>
                            <ComboBoxItem Content="跟随系统" Tag="Auto"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="#F8F9FA" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="恢复默认" Style="{StaticResource ModernButtonStyle}" 
                        Background="#FF9800" Command="{Binding ResetDefaultCommand}"/>
                <Button Content="取消" Style="{StaticResource ModernButtonStyle}" 
                        Background="#757575" Command="{Binding CancelCommand}"/>
                <Button Content="保存" Style="{StaticResource ModernButtonStyle}" 
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>