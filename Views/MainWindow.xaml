<Window x:Class="AIAnswerTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIAnswerTool.Views"
        mc:Ignorable="d"
        Title="柚子皮 AI答题助手" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="800"
        Background="#F8F9FA"
        Topmost="{Binding IsWindowTopmost}">
    
    <Window.Resources>
        <!-- 转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- 布尔值到背景色转换器 -->
        <Style x:Key="BoolToBackgroundConverter" TargetType="{x:Type Border}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                    <Setter Property="Background" Value="#E8F5E8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                    <Setter Property="Background" Value="#FFF3E0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- 布尔值到前景色转换器 -->
        <Style x:Key="BoolToForegroundConverter" TargetType="{x:Type TextBlock}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                    <Setter Property="Foreground" Value="#2E7D32"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                    <Setter Property="Foreground" Value="#F57C00"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- 渐变背景 -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F8F9FA" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- 现代化按钮样式 -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#667eea"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#764ba2"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#667eea" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a67d8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 主要操作按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <!-- 危险操作按钮样式 -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#FF5722"/>
        </Style>
        
        <!-- 现代化文本框样式 -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#667eea"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#667eea"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#667eea" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardGradient}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- GroupBox样式 -->
        <Style x:Key="ModernGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" 
                                    CornerRadius="8,8,0,0" Padding="15,10">
                                <ContentPresenter ContentSource="Header" 
                                                TextElement.Foreground="White"
                                                TextElement.FontWeight="Bold"
                                                TextElement.FontSize="16"/>
                            </Border>
                            <Border Grid.Row="1" Background="White" 
                                    CornerRadius="0,0,8,8" 
                                    BorderThickness="1" 
                                    BorderBrush="#E0E0E0">
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 应用标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🎓" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="柚子皮 AI答题助手" FontSize="20" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 快捷键提示 -->
                <TextBlock Grid.Column="1" Text="快捷键: Ctrl+Alt+Q 唤醒窗口 | Ctrl+Alt+S 快速截图" 
                           FontSize="12" Foreground="#E8E8E8" VerticalAlignment="Center" 
                           HorizontalAlignment="Center" Margin="20,0"/>
                
                <!-- 工具按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Name="btnScreenshot" Content="📷 截图" Style="{StaticResource ModernButtonStyle}" 
                            Command="{Binding ScreenshotCommand}" Background="#4CAF50"/>
                    <Button Name="btnSettings" Content="⚙️ 设置" Style="{StaticResource ModernButtonStyle}" 
                            Command="{Binding SettingsCommand}" Background="#FF9800"/>
                    <CheckBox Name="chkTopmost" Content="置顶" IsChecked="{Binding IsWindowTopmost}" 
                              VerticalAlignment="Center" Margin="15,0,10,0" Foreground="White" FontWeight="Medium"/>
                    <Button Name="btnTestConnection" Content="🔗 测试" Style="{StaticResource ModernButtonStyle}" 
                            Command="{Binding TestConnectionCommand}" Background="#2196F3"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：题目输入卡片 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <GroupBox Header="📝 题目内容" Style="{StaticResource ModernGroupBoxStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 题目类型选择 -->
                        <Border Grid.Row="0" Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 题目类型:" VerticalAlignment="Center" Margin="0,0,15,0" 
                                           FontWeight="Medium" Foreground="#495057"/>
                                <ComboBox Name="cmbQuestionType" Width="150" Height="35" 
                                          SelectedValue="{Binding SelectedQuestionType}"
                                          FontSize="14" Padding="10,5">
                                    <ComboBoxItem Content="🤖 自动识别" Tag="Auto"/>
                                    <ComboBoxItem Content="📊 选择题" Tag="Choice"/>
                                    <ComboBoxItem Content="✏️ 填空题" Tag="FillBlank"/>
                                    <ComboBoxItem Content="💭 问答题" Tag="QA"/>
                                    <ComboBoxItem Content="🧮 计算题" Tag="Calculation"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        
                        <!-- 题目文本输入 -->
                        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderThickness="2" 
                                BorderBrush="#E9ECEF" Padding="5">
                            <TextBox Name="txtQuestion" 
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     TextWrapping="Wrap" 
                                     AcceptsReturn="True" 
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="15"
                                     BorderThickness="0"
                                     Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"/>
                        </Border>
                        
                        <!-- 操作按钮区域 -->
                        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 左侧提示 -->
                                <TextBlock Grid.Column="0" Text="💡 提示: 可以直接输入题目或使用截图功能" 
                                           VerticalAlignment="Center" FontSize="12" Foreground="#6C757D"/>
                                
                                <!-- 右侧按钮 -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Name="btnClear" Content="🗑️ 清空" Style="{StaticResource DangerButtonStyle}" 
                                            Command="{Binding ClearCommand}" Margin="0,0,10,0"/>
                                    <Button Name="btnGetAnswer" Content="🚀 获取答案" Style="{StaticResource PrimaryButtonStyle}" 
                                            Command="{Binding GetAnswerCommand}" IsEnabled="{Binding IsNotProcessing}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>
            </Border>
            
            <!-- 中间：答案显示区域 -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <GroupBox Header="🎯 智能解答" Style="{StaticResource ModernGroupBoxStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 答案显示区域 -->
                            <Border Grid.Row="0" Background="#FAFBFC" CornerRadius="8" 
                                    BorderThickness="1" BorderBrush="#E9ECEF" Padding="20">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock Name="txtAnswer" 
                                               TextWrapping="Wrap" 
                                               FontSize="15"
                                               Foreground="#212529"
                                               Text="{Binding AnswerText}"/>
                                </ScrollViewer>
                            </Border>
                            
                            <!-- 状态信息栏 -->
                            <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" 
                                    Padding="15" Margin="0,15,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#28A745" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Name="txtStatus" Text="{Binding StatusText}" 
                                                   VerticalAlignment="Center" FontWeight="Medium" Foreground="#495057"/>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="1" Name="txtTokenUsage" Text="{Binding TokenUsageText}" 
                                               VerticalAlignment="Center" FontSize="12" Foreground="#6C757D"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Border>
            
            <!-- 右侧：参考选项区域 -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <GroupBox Header="📋 参考选项" Style="{StaticResource ModernGroupBoxStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 最终答案标题 -->
                            <Border Grid.Row="0" Background="#E8F5E8" CornerRadius="6" Padding="12,8" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎯" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="最终答案" FontSize="14" FontWeight="Bold" 
                                               Foreground="#2E7D32" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- 参考选项显示区域 -->
                            <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="8" 
                                    BorderThickness="2" BorderBrush="#4CAF50" Padding="20" MinHeight="120">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Name="pnlReferenceOptions">
                                        <!-- 选择题选项 -->
                                        <StackPanel Name="pnlChoiceOptions" Visibility="{Binding ChoiceOptionsVisibility}">
                                            <ItemsControl Name="icChoiceOptions" ItemsSource="{Binding ChoiceOptions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                                                             <Border.Style>
                                                                 <Style TargetType="Border">
                                                                     <Setter Property="Background" Value="#FFF3E0"/>
                                                                     <Style.Triggers>
                                                                         <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                             <Setter Property="Background" Value="#E8F5E8"/>
                                                                         </DataTrigger>
                                                                     </Style.Triggers>
                                                                 </Style>
                                                             </Border.Style>
                                                             <StackPanel Orientation="Horizontal">
                                                                 <TextBlock Text="{Binding OptionLabel}" FontWeight="Bold" 
                                                                            Margin="0,0,8,0" FontSize="16">
                                                                     <TextBlock.Style>
                                                                         <Style TargetType="TextBlock">
                                                                             <Setter Property="Foreground" Value="#F57C00"/>
                                                                             <Style.Triggers>
                                                                                 <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                                     <Setter Property="Foreground" Value="#2E7D32"/>
                                                                                 </DataTrigger>
                                                                             </Style.Triggers>
                                                                         </Style>
                                                                     </TextBlock.Style>
                                                                 </TextBlock>
                                                                 <TextBlock Text="{Binding OptionText}" 
                                                                            TextWrapping="Wrap" FontSize="14">
                                                                     <TextBlock.Style>
                                                                         <Style TargetType="TextBlock">
                                                                             <Setter Property="Foreground" Value="#F57C00"/>
                                                                             <Style.Triggers>
                                                                                 <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                                     <Setter Property="Foreground" Value="#2E7D32"/>
                                                                                 </DataTrigger>
                                                                             </Style.Triggers>
                                                                         </Style>
                                                                     </TextBlock.Style>
                                                                 </TextBlock>
                                                             </StackPanel>
                                                         </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        
                                        <!-- 判断题答案 -->
                                        <StackPanel Name="pnlJudgmentAnswer" Visibility="{Binding JudgmentAnswerVisibility}">
                                            <Border Background="#E8F5E8" CornerRadius="8" Padding="20">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding JudgmentIcon}" FontSize="24" 
                                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <TextBlock Text="{Binding JudgmentText}" FontSize="18" FontWeight="Bold" 
                                                               Foreground="#2E7D32" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        
                                        <!-- 其他题型答案 -->
                                        <StackPanel Name="pnlOtherAnswer" Visibility="{Binding OtherAnswerVisibility}">
                                            <Border Background="#F0F8FF" CornerRadius="8" Padding="20">
                                                <TextBlock Name="txtFinalAnswer" Text="{Binding FinalAnswerText}" 
                                                           TextWrapping="Wrap" FontSize="16" FontWeight="Medium" 
                                                           Foreground="#1565C0" HorizontalAlignment="Center" 
                                                           TextAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        
                                        <!-- 空状态提示 -->
                                        <StackPanel Name="pnlEmptyState" Visibility="{Binding EmptyStateVisibility}">
                                            <Border Background="#F8F9FA" CornerRadius="8" Padding="30">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="📝" FontSize="32" HorizontalAlignment="Center" 
                                                               Margin="0,0,0,10" Opacity="0.5"/>
                                                    <TextBlock Text="请先获取题目答案" FontSize="14" 
                                                               Foreground="#6C757D" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Border>
        </Grid>
        
        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#343A40" Height="35">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧状态信息 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#28A745" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Name="txtStatusBar" Text="就绪" FontSize="12" Foreground="#F8F9FA" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 中间分隔符 -->
                <Rectangle Grid.Column="1" Width="1" Height="20" Fill="#495057" Margin="15,0" VerticalAlignment="Center"/>
                
                <!-- 右侧版本信息 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🚀" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Name="txtVersion" Text="KaKaDa AI v1.0.0" FontSize="12" Foreground="#ADB5BD" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>